# Supabase project settings (Project Settings > API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Only used server-side (migration scripts, admin tasks, Midtrans webhook/cron) — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Midtrans (billing) — from the Midtrans dashboard, Sandbox settings until ready to go live.
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` — set the
# same value in Vercel's env vars for the /api/cron/subscription-sweep route.
CRON_SECRET=

# Google Analytics 4 Measurement ID (from analytics.google.com, format G-XXXXXXXXXX).
# Leave blank to disable tracking entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
