# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase local dev
/supabase/.branches
/supabase/.temp

# local Claude Code settings
/.claude/settings.local.json

# kalkulator HPP desktop app — installer binary served from here at runtime
# (src/app/api/kalkulator-hpp-desktop/download/route.ts), never committed
/private-assets
desktop-app/node_modules
desktop-app/dist
